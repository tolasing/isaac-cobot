# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Isaac Sim / Omniverse local caches (never commit these)
*.usd.bak
kit_cache/
.nvidia-omniverse/

# Vendored third-party asset packs (too large for git) -- see each
# directory's own SOURCE.md for provenance + how to re-fetch.
assets/factory/*
!assets/factory/SOURCE.md

# Hand-authored scanner-assembly scene + vendor CAD source -- same
# reasoning as assets/factory/ above (large, vendor-origin, no
# established redistribution terms of their own).
assets/mefron/*
mantra scanner/*

# Locally-vendored NVIDIA Isaac Franka Panda asset (collected from Nucleus
# to work around an instanceable-geometry/ancestral-prim restriction -- see
# robots/franka_panda/SOURCE.md). Same reasoning as assets/factory/ above.
robots/franka_panda/*
!robots/franka_panda/SOURCE.md

# Session screen recordings -- debugging artifacts, never meant to be committed.
*.webm

# Docker container.py runtime state
docker/.container.cfg
docker/.isaac-cobot-docker-history

# Session scratch output -- never meant to be committed
scratchpad/*

# Editors / OS
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# Secrets - never commit tokens or env overrides
.env
.env.local
*.token
